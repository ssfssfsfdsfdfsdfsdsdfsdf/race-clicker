-- ─── Core functions ──────────────────────────────────────────
local function tweenTo(pos)
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local targetPos = pos + Vector3.new(0, 3, 0)
    local tweenInfo = TweenInfo.new(tweenDuration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
    local goal = {CFrame = CFrame.new(targetPos) * hrp.CFrame.Rotation}
    local tween = TweenService:Create(hrp, tweenInfo, goal)
    tween:Play()
    tween.Completed:Wait()
end

local function stopFarm()
    farming = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
    btnFarm.Text = "▶ Start Farm"
    btnFarm.BackgroundColor3 = Color3.fromRGB(50,180,80)
    statusLabel.Text = "Farm: Stopped"
end

local function startFarm()
    if farming then return end
    farming = true
    btnFarm.Text = "⏹ Stop Farm"
    btnFarm.BackgroundColor3 = Color3.fromRGB(180,50,50)
    statusLabel.Text = "Farm: Running"

    farmThread = task.spawn(function()
        local idx = 1
        while farming do
            local target = waypoints[idx]
            statusLabel.Text = string.format("Moving to point %d", idx)
            tweenTo(target)
            statusLabel.Text = string.format("At point %d – waiting…", idx)
            -- 🔥 always wait at least 0.01s (never zero)
            task.wait(loopDelay)
            idx = idx % #waypoints + 1
        end
    end)
end

btnFarm.MouseButton1Click:Connect(function()
    if farming then
        stopFarm()
    else
        startFarm()
    end
end)

-- ─── Noclip system ───────────────────────────────────────────
local function enableNoclip()
    if noclip then return end
    noclip = true
    btnNoclip.Text = "👻 Noclip: ON"
    btnNoclip.BackgroundColor3 = Color3.fromRGB(30, 160, 80)

    local char = player.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CanCollide = false
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1e5, 0, 1e5)
        bodyVelocity.Velocity = Vector3.zero
        bodyVelocity.P = 5000
        bodyVelocity.Parent = hrp
    end

    noclipConnection = RunService.Heartbeat:Connect(function()
        if not noclip or not char or not char.Parent then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and bodyVelocity then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                local moveDir = humanoid.MoveDirection * 60
                bodyVelocity.Velocity = moveDir
            end
        end
    end)
end

local function disableNoclip()
    noclip = false
    btnNoclip.Text = "👻 Noclip: OFF"
    btnNoclip.BackgroundColor3 = Color3.fromRGB(80,80,100)

    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end

    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end

    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CanCollide = true
        end
    end
end

btnNoclip.MouseButton1Click:Connect(function()
    if noclip then
        disableNoclip()
    else
        enableNoclip()
    end
end)

